-- Auto RakNet Desync Mobile + UI + เปลี่ยนสีตัวละคร
-- เปิด Desync = ตัวเขียว | ปิด Desync = ตัวแดง

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local lp = Players.LocalPlayer
local character = lp.Character or lp.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

local hooked = false
local desyncEnabled = true

-- ================== ฟังก์ชันจัดการ Desync ==================
local function enableDesync()
    if Raknet and Raknet.desync then
        Raknet.desync(true)
        print("✅ Desync ON via Raknet.desync")
        return true
    elseif raknet and raknet.desync then
        raknet.desync(true)
        print("✅ Desync ON via raknet.desync")
        return true
    elseif raknet and raknet.add_send_hook then
        raknet.add_send_hook(function(packet)
            if packet.PacketId == 0x1B then
                local buf = packet.AsBuffer
                buffer.writeu32(buf, 1, 0xFFFFFFFF)
                packet:SetData(buf)
            end
        end)
        print("✅ Desync ON via RakNet Hook")
        return true
    end
    return false
end

local function disableDesync()
    if Raknet and Raknet.desync then
        Raknet.desync(false)
    elseif raknet and raknet.desync then
        raknet.desync(false)
    elseif raknet and raknet.remove_send_hook then
        raknet.remove_send_hook()
    end
    print("❌ Desync OFF")
end

-- ================== ฟังก์ชันเปลี่ยนสีตัวละคร ==================
local function setCharacterColor(color)
    if not character then return end
    
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.Color = color
            -- ถ้ามี Highlight หรือ Material ก็ปรับให้ดูชัด
            if part:FindFirstChild("Highlight") then
                part.Highlight.FillColor = color
            end
        end
    end
end

local function updateCharacterColor()
    if desyncEnabled then
        setCharacterColor(Color3.fromRGB(0, 255, 100))   -- เขียวสด
    else
        setCharacterColor(Color3.fromRGB(255, 50, 50))   -- แดงสด
    end
end

-- ================== สร้าง UI ==================
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "DesyncColorUI"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = lp:WaitForChild("PlayerGui")

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 240, 0, 160)
MainFrame.Position = UDim2.new(0.5, -120, 0.35, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Draggable = true
MainFrame.Parent = ScreenGui

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 14)
UICorner.Parent = MainFrame

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 45)
Title.BackgroundTransparency = 1
Title.Text = "🔥 RakNet Desync + Color"
Title.TextColor3 = Color3.fromRGB(255, 215, 0)
Title.TextScaled = true
Title.Font = Enum.Font.GothamBold
Title.Parent = MainFrame

local Status = Instance.new("TextLabel")
Status.Size = UDim2.new(1, 0, 0, 35)
Status.Position = UDim2.new(0, 0, 0, 45)
Status.BackgroundTransparency = 1
Status.Text = "สถานะ: กำลังเปิด..."
Status.TextColor3 = Color3.fromRGB(0, 255, 100)
Status.TextScaled = true
Status.Font = Enum.Font.GothamSemibold
Status.Parent = MainFrame

local ToggleButton = Instance.new("TextButton")
ToggleButton.Size = UDim2.new(0.88, 0, 0, 50)
ToggleButton.Position = UDim2.new(0.06, 0, 0, 90)
ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
ToggleButton.Text = "ปิด Desync"
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.TextScaled = true
ToggleButton.Font = Enum.Font.GothamBold
ToggleButton.Parent = MainFrame

local ButtonCorner = Instance.new("UICorner")
ButtonCorner.CornerRadius = UDim.new(0, 12)
ButtonCorner.Parent = ToggleButton

-- ================== อัปเดต UI + สี ==================
local function updateUI()
    if desyncEnabled then
        Status.Text = "เปิด)"
        Status.TextColor3 = Color3.fromRGB(0, 255, 100)
        ToggleButton.Text = "ปิด Desync"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
    else
        Status.Text = "ปิด"
        Status.TextColor3 = Color3.fromRGB(255, 60, 60)
        ToggleButton.Text = "เปิด Desync"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    end
    updateCharacterColor()
end

-- ================== Toggle ==================
ToggleButton.MouseButton1Click:Connect(function()
    desyncEnabled = not desyncEnabled
    
    if desyncEnabled then
        if enableDesync() then
            hooked = true
        else
            desyncEnabled = false
            warn("⚠️ ไม่พบ RakNet library! กรุณาใช้ Delta Executor ล่าสุด")
        end
    else
        disableDesync()
        hooked = false
    end
    
    updateUI()
end)

-- ================== เริ่มต้นอัตโนมัติ ==================
task.spawn(function()
    task.wait(0.8) -- รอตัวละครและ Raknet โหลด
    
    -- โหลดตัวละครใหม่เมื่อ respawn
    lp.CharacterAdded:Connect(function(newChar)
        character = newChar
        task.wait(0.5)
        updateCharacterColor()
    end)
    
    if enableDesync() then
        hooked = true
        desyncEnabled = true
        print("🚀 Auto Desync + Color เปิดแล้ว (ตัวเขียว)")
    else
        desyncEnabled = false
        print("⚠️ ไม่พบ RakNet! แนะนำอัปเดต Delta")
    end
    
    updateUI()
end)

-- กด U เพื่อ toggle เร็ว
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.U then
        ToggleButton.MouseButton1Click:Fire()
    end
end)

print("✅ Desync UI + Color Loaded!")
print("   เปิด = ตัวเขียว | ปิด = ตัวแดง")
print("   กดปุ่มใน UI หรือกด U เพื่อสลับ")
